<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_spa_therapist_tree" model="ir.ui.view">
        <field name="name">spa.therapist.tree</field>
        <field name="model">spa.therapist</field>
        <field name="arch" type="xml">
            <list string="Spa Therapists">
                <field name="name"/>
                <field name="employee_id"/>
<!--                <field name="branch_id"/>-->
                <field name="mobile"/>
                <field name="email"/>
<!--                <field name="monthly_target"/>-->
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_spa_therapist_form" model="ir.ui.view">
        <field name="name">spa.therapist.form</field>
        <field name="model">spa.therapist</field>
        <field name="arch" type="xml">
            <form string="Spa Therapist">

                <sheet>

                    <!-- Title with Image -->
                    <div class="oe_title">
                        <field name="image" widget="image"
                               class="oe_avatar"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>

                    <!-- Basic Information -->
                    <group string="Therapist Information">
                        <group>
                            <field name="employee_id"/>
<!--                            <field name="user_id"/>-->
<!--                            <field name="branch_id"/>-->
                            <field name="active"/>
                        </group>

                        <group>
                            <field name="mobile"/>
                            <field name="email"/>
                            <field name="specialization"/>
                            <field name="color" widget="color_picker"/>
                        </group>
                    </group>

                    <!-- Skills -->
<!--                    <group string="Skills  Services">-->
<!--                        <field name="skill_ids" widget="many2many_tags"/>-->
<!--                    </group>-->


<!--                    <notebook>-->

<!--                        <page string="Appointments">-->
<!--                            <field name="appointment_ids" readonly="1">-->
<!--                                <list>-->
<!--                                    <field name="therapist_id" invisible="1"/>-->
<!--                                    &lt;!&ndash; Example fields (adjust if needed) &ndash;&gt;-->
<!--                                    <field name="start_datetime"/>-->
<!--                                    <field name="end_datetime"/>-->
<!--                                    <field name="state"/>-->
<!--                                </list>-->
<!--                            </field>-->
<!--                       </page>-->
<!--                    </notebook>-->
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_spa_therapist" model="ir.actions.act_window">
        <field name="name">Therapists</field>
        <field name="res_model">spa.therapist</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
