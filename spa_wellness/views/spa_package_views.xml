<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_spa_package_template_list" model="ir.ui.view">
        <field name="name">spa.package.template.list</field>
        <field name="model">spa.package.template</field>
        <field name="arch" type="xml">
            <list string="Package Templates">
                <field name="name"/>
                <field name="price"/>
                <field name="validity_days"/>
            </list>
        </field>
    </record>

    <record id="view_spa_package_template_form" model="ir.ui.view">
        <field name="name">spa.package.template.form</field>
        <field name="model">spa.package.template</field>
        <field name="arch" type="xml">
            <form string="Package Template">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Package Name"/></h1>
                    </div>

                    <group>
                        <group string="Pricing">
                            <field name="price"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="validity_days"/>
                        </group>
                        <group string="Status">
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Services Included">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="service_id"/>
                                    <field name="sessions"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_spa_package_template" model="ir.actions.act_window">
        <field name="name">Package Templates</field>
        <field name="res_model">spa.package.template</field>
        <field name="view_mode">list,form</field>
    </record>



</odoo>