<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_spa_therapist_commission_tree" model="ir.ui.view">
        <field name="name">spa.therapist.commission.tree</field>
        <field name="model">spa.therapist.commission</field>
        <field name="arch" type="xml">
            <list string="Therapist Commissions">
                <field name="appointment_id"/>
                <field name="therapist_id"/>
                <field name="service_id"/>
                <field name="service_amount"/>
                <field name="commission_type"/>
                <field name="commission_value"/>
                <field name="commission_amount"/>
            </list>

        </field>
    </record>

    <record id="action_spa_therapist_commission" model="ir.actions.act_window">
        <field name="name">Therapist Commissions</field>
        <field name="res_model">spa.therapist.commission</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
