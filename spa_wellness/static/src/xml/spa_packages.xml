<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="spa_wellness.SpaPackages">
        <div class="smp-page">
            <!-- HEADER -->
            <div class="smp-header">
                <button class="smp-back-btn" t-on-click="goBack">← Back</button>
                <div class="smp-title-wrap">
                    <span class="smp-icon">🎁</span>
                    <h2 class="smp-title">Spa Packages</h2>
                </div>
                <button class="btn btn-primary" t-on-click="openBookingPanel">
                    + New Booking
                </button>
                <span class="smp-subtitle">
                    Package services bundled together
                </span>
            </div>
            <!-- LOADING -->
            <div t-if="state.loading" class="smp-loading">
                <i class="fa fa-spinner fa-spin fa-2x"/>
                <span>Loading packages…</span>
            </div>
            <!-- PACKAGE GRID -->
            <div t-if="!state.loading" class="smp-grid">
                <t t-if="state.packages.length === 0">
                    <div class="smp-empty">No packages available.</div>
                </t>
                <t t-foreach="state.packages" t-as="pkg" t-key="pkg.id">
                    <div class="smp-card"
                         t-on-click="() => this.openPackage(pkg.id)">
                        <!-- HEADER -->
                        <div class="smp-card-header">
                            <div class="smp-plan-icon">🎁</div>

                            <div class="smp-plan-name"
                                 t-esc="pkg.name"/>

                            <div class="smp-plan-price">
                                <span class="smp-currency">BHD</span>
                                <span class="smp-amount"
                                      t-esc="pkg.priceLabel"/>
                            </div>
                        </div>
                        <!-- VALIDITY -->
                        <div class="smp-duration-badge">
                            📅 <t t-esc="pkg.validityLabel"/>
                        </div>
                        <div class="smp-divider"/>
                        <!-- SERVICES -->
                        <div class="smp-section">
                            <div class="smp-section-title">
                                🧖 Services Included
                            </div>
                            <t t-if="pkg.lines.length === 0">
                                <div class="smp-no-data">
                                    No services added
                                </div>
                            </t>
                            <t t-foreach="pkg.lines"
                               t-as="line"
                               t-key="line.id">
                                <div class="smp-service-row">
                                    <span class="smp-service-name"
                                          t-esc="line.service_id ? line.service_id[1] : '—'"/>

                                    <span class="smp-badge smp-badge-teal">
                                        <t t-esc="line.sessions"/> sessions
                                    </span>
                                </div>
                            </t>
                        </div>
                        <div class="smp-card-footer">
                            Book Now →</div>
                    </div>
                </t>
            </div>
        </div>
    </t>
</templates>